.page {
  min-height: 100vh;
  background: linear-gradient(180deg, #f6f9ff 0%, #fefefe 70%);
  padding: 32rpx;
}

.hero {
  background: #fff;
  border-radius: 28rpx;
  padding: 48rpx 36rpx;
  text-align: center;
  box-shadow: 0 24rpx 60rpx rgba(43, 89, 255, 0.1);
  margin-bottom: 32rpx;
}

.app-name {
  font-size: 36rpx;
  font-weight: 700;
  color: #2f3b66;
}

.tagline {
  margin-top: 12rpx;
  font-size: 26rpx;
  color: #7c88b6;
}

.card {
  background: #fff;
  border-radius: 24rpx;
  padding: 32rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 16rpx 40rpx rgba(29, 52, 129, 0.08);
}

.title {
  font-size: 30rpx;
  font-weight: 600;
  color: #1f1f1f;
  margin-bottom: 16rpx;
}

.content {
  font-size: 26rpx;
  color: #555;
  line-height: 1.7;
}

.content.list text {
  display: block;
  margin-bottom: 8rpx;
}
