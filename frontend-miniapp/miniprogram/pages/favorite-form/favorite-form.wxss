.favorite-form-page {
  min-height: 100vh;
  background: #f5f6fa;
  padding-bottom: 140rpx;
}

.card {
  background: #fff;
  margin: 20rpx;
  padding: 24rpx;
  border-radius: 18rpx;
  box-shadow: 0 10rpx 30rpx rgba(0, 0, 0, 0.05);
}

.form-item + .form-item {
  margin-top: 24rpx;
}

.label {
  font-size: 28rpx;
  color: #444;
  margin-bottom: 12rpx;
}

input,
textarea {
  width: 100%;
  border: 1rpx solid #e0e0e0;
  border-radius: 12rpx;
  padding: 20rpx;
  font-size: 28rpx;
  background: #fafafa;
}

textarea {
  min-height: 160rpx;
}

.type-group {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.type-option {
  display: flex;
  align-items: center;
  padding: 16rpx 20rpx;
  border: 1rpx solid #ddd;
  border-radius: 12rpx;
  font-size: 26rpx;
  color: #555;
}

.type-option.checked {
  border-color: #764ba2;
  background: rgba(118, 75, 162, 0.08);
  color: #764ba2;
}

.type-option radio {
  margin-right: 10rpx;
  transform: scale(0.8);
}

.error {
  color: #ff4d4f;
  font-size: 24rpx;
  margin-top: 8rpx;
}

.map-card {
  margin-top: 0;
}

.map-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 16rpx;
}

.map-title {
  font-size: 30rpx;
  font-weight: 600;
}

.map-desc {
  font-size: 24rpx;
  color: #999;
}

.btn-map {
  background: linear-gradient(135deg, #36d1dc 0%, #5b86e5 100%);
  color: #fff;
  border: none;
  border-radius: 999rpx;
  padding: 0 24rpx;
}

.mini-map {
  width: 100%;
  height: 360rpx;
  border-radius: 18rpx;
  overflow: hidden;
}

.address-info {
  margin-top: 20rpx;
  background: #f7f9fc;
  border-radius: 12rpx;
  padding: 16rpx;
}

.address-value {
  margin-top: 8rpx;
  font-size: 26rpx;
  color: #555;
}

.bottom-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  padding: 20rpx;
  background: rgba(255, 255, 255, 0.95);
  box-shadow: 0 -6rpx 16rpx rgba(0, 0, 0, 0.08);
}

.btn-save {
  width: 100%;
  height: 96rpx;
  line-height: 96rpx;
  border: none;
  border-radius: 999rpx;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  color: #fff;
  font-size: 32rpx;
  font-weight: 600;
  letter-spacing: 2rpx;
}


