.favorite-page {
  min-height: 100vh;
  background: #f5f6fa;
  padding: 20rpx;
}

.filter-card {
  background: #fff;
  border-radius: 16rpx;
  padding: 20rpx;
  box-shadow: 0 8rpx 24rpx rgba(116, 75, 162, 0.08);
  margin-bottom: 20rpx;
}

.filter-tabs {
  white-space: nowrap;
  display: flex;
  margin-bottom: 20rpx;
}

.filter-tab {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  padding: 10rpx 24rpx;
  border-radius: 999rpx;
  font-size: 26rpx;
  color: #666;
  margin-right: 16rpx;
  border: 1rpx solid #ddd;
}

.filter-tab.active {
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  color: #fff;
  border: none;
  box-shadow: 0 6rpx 16rpx rgba(102, 126, 234, 0.35);
}

.btn-add {
  width: 100%;
  background: linear-gradient(135deg, #ff9a9e 0%, #fad0c4 100%);
  color: #fff;
  border: none;
  border-radius: 12rpx;
  font-size: 28rpx;
}

.list-card {
  background: #fff;
  border-radius: 16rpx;
  box-shadow: 0 8rpx 24rpx rgba(0, 0, 0, 0.05);
}

.favorite-item {
  padding: 24rpx;
  border-bottom: 1rpx solid #f0f0f0;
}

.favorite-item:last-child {
  border-bottom: none;
}

.item-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 16rpx;
}

.item-name {
  font-size: 32rpx;
  font-weight: 600;
  color: #333;
}

.type-tag {
  font-size: 24rpx;
  color: #764ba2;
  background: rgba(118, 75, 162, 0.1);
  padding: 6rpx 16rpx;
  border-radius: 999rpx;
}

.item-row {
  display: flex;
  font-size: 26rpx;
  color: #666;
  margin-bottom: 8rpx;
}

.item-row:last-child {
  margin-bottom: 0;
}

.label {
  width: 80rpx;
  color: #999;
}

.value {
  flex: 1;
}

.empty {
  margin-top: 120rpx;
  text-align: center;
  color: #999;
  font-size: 28rpx;
}


