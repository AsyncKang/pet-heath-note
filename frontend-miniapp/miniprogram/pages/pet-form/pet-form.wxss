.form-card {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.form-item {
  display: flex;
  flex-direction: column;
}

.label {
  font-size: 26rpx;
  color: #666;
  margin-bottom: 8rpx;
}

input,
textarea {
  border: 1rpx solid #ddd;
  border-radius: 8rpx;
  padding: 16rpx;
  background: #fafafa;
}

.picker-value {
  border: 1rpx solid #ddd;
  border-radius: 8rpx;
  padding: 16rpx;
  background: #fff;
  display: flex;
  align-items: center;
  justify-content: space-between;
  color: #333;
}

.picker-value::after {
  content: '▼';
  font-size: 22rpx;
  color: #999;
}

.submit-btn {
  margin-top: 32rpx;
}

.avatar-item {
  margin-bottom: 12rpx;
}

.avatar-upload {
  display: flex;
  align-items: center;
  gap: 20rpx;
}

.avatar-box {
  width: 200rpx;
  height: 200rpx;
  border-radius: 32rpx;
  background: #f7f8fa;
  border: 2rpx dashed #c9cdd4;
  display: flex;
  align-items: center;
  justify-content: center;
  overflow: hidden;
}

.avatar-preview {
  width: 100%;
  height: 100%;
  border-radius: 32rpx;
}

.avatar-placeholder {
  display: flex;
  flex-direction: column;
  align-items: center;
  color: #999;
  font-size: 24rpx;
}

.avatar-placeholder .plus {
  font-size: 48rpx;
  line-height: 1;
}

.avatar-placeholder .tip {
  margin-top: 8rpx;
}

.btn-secondary {
  background: #f0f1f5;
  color: #666;
  border: none;
  border-radius: 999rpx;
  padding: 0 32rpx;
}


