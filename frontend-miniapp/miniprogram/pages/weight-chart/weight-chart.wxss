.weight-chart-page {
  min-height: 100vh;
  background: #f5f6fa;
  padding: 20rpx;
}

.card {
  background: #fff;
  border-radius: 18rpx;
  padding: 24rpx;
  box-shadow: 0 10rpx 30rpx rgba(0, 0, 0, 0.05);
  margin-bottom: 20rpx;
}

.info-card .title {
  font-size: 32rpx;
  font-weight: 600;
}

.info-card .subtitle {
  margin-top: 8rpx;
  color: #888;
  font-size: 24rpx;
}

.chart-card {
  position: relative;
}

.chart-canvas {
  width: 100%;
  height: 360rpx;
}

.empty {
  text-align: center;
  color: #999;
  font-size: 28rpx;
  padding: 80rpx 0;
}

.loading {
  text-align: center;
  color: #888;
  margin-top: 20rpx;
}


